# --- App ---
SECRET_KEY=change-me-to-a-long-random-string
# Set to 1 to bypass Azure AD and log in as a demo user (local dev only):
DEV_LOGIN=0
# When DEV_LOGIN=1, switch users via /login?as=<email> or /login?as=<user_id>

# --- Database ---
# SQLite (default, zero-install):
DATABASE_URL=sqlite:///./data/expenses.db
# PostgreSQL example (uncomment + install psycopg):
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/expenses

# --- Receipts / OCR ---
RECEIPTS_DIR=./receipts
RECEIPT_MAX_BYTES=10485760
# Path to the Tesseract executable on Windows:
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- Azure AD (only needed when DEV_LOGIN=0) ---
AAD_TENANT_ID=
AAD_CLIENT_ID=
AAD_CLIENT_SECRET=
AAD_REDIRECT_URI=http://localhost:8000/auth/callback

# --- Backups (optional) ---
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14

# --- Notifications (optional — logs only when SMTP not set) ---
APP_BASE_URL=http://localhost:8000
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=1
